{
  "name": "weatherv2",
  "version": "1.0.0",
  "description": "天气预报 Web 应用（Angualr + Ts + Angular/CLI）",
  "license": "MIT",
  "scripts": {
    "dev": "ng serve",
    "build": "ng build --base-href /",
    "preview": "ng build && npx serve ./dist/weatherv2/browser",
    "lint": "eslint \"src/**/*.{ts,html}\"",
    "lint:fix": "eslint \"src/**/*.{ts,html}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,scss,json}\"",
    "type-check": "tsc --noEmit -p tsconfig.app.json",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.html": [
      "eslint --fix",
      "prettier --write --parser angular"
    ],
    "src/**/*.{css,scss,json}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Chauncey",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^9.39.3",
    "angular-eslint": "^21.2.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.8"
  }
}
